# Express API base (includes /api/v1)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Optional: server origin for product images + Vite /uploads proxy target
# VITE_API_ORIGIN=http://localhost:3000

# Stripe publishable key (pk_test_... local, pk_live_... production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Production (Vercel) — see .env.production.example and STRIPE_LIVE_SETUP.md
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
# VITE_API_ORIGIN=https://api.yourdomain.com
# VITE_FORCE_ABSOLUTE_UPLOADS=true
